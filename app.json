        "backgroundColor": "#2D6A4F"
      },
      "package": "com.marketdistributor.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font"
      ]
    ]
  }
}
